10  ' --- INICIALIZACION ---
20  F$ = "MOLDURAS.TXT"  'NOMBRE DEL ARCHIVO DE GUARDADO

100 ' --- MENU PRINCIPAL ---
110 CLS                     'LIMPIA LA PANTALLA
120 PRINT "1: CAPTURA"
130 PRINT "2: DESCARGA"
140 PRINT "3: BORRAR"           'VARIABLES DE MENU
150 PRINT "4: VER DATOS"
160 PRINT "5: SALIR"
170 PRINT "Elija opcion: [0-5]"
180 O$ = INKEY$             'LECTURA DE UNA UNICA TECLA QUE SE GUARDA EN UNA VARIABLE O$
190 IF O$ = "" THEN
191   GOTO 180
192 END IF
200 IF O$ = "1" THEN
201   GOTO 1000
202 END IF
210 IF O$ = "2" THEN        'LUGARES DEL CODIGO DONDE LLEVA CADA COMANDO DE EJECUCION
211   GOTO 2000                 'Si O$ ESTA VACIO VUELVE A SEGUIR ESCUCHANDO
212 END IF
220 IF O$ = "3" THEN
221   GOTO 3000
222 END IF
230 IF O$ = "4" THEN
231   GOTO 4000
232 END IF
240 IF O$ = "5" THEN
241   GOTO 5000
242 END IF
250 GOTO 100

1000 ' --- 1: CAPTURA ---
1010 CLS
1020 PRINT "Escanee Codigo:"
1030 OPEN "BAR:" AS #1          'ENCENDIDO DEL LECTOR LASER EN CANAL 1
1040 WAIT 0,1                   'ESPERA PARA APRETAR GATILLO
1050 INPUT #1, CODIGO$          'LEE CB EN CANAL 1 Y LO GUARDA EN LA VARIABLE CODIGO
1060 CLOSE #1                   'APAGA EL LECTOR LASER 
1070 BEEP 1                     'PITIDO DE CONFIRMACION
1080 PRINT CODIGO$              'MUESTRA CODIGO ESCANEADO
1090 PRINT "Cantidad:"          
1100 INPUT "", CANTIDAD$            'VARIABLE PARA LA CANTIDAD DE MOLDURAS A COGER.
1110 PRINT "[1:Guardar] [2:Borrar]"
1120 ACCION$ = INKEY$               'ESPERA DE SELECCION
1130 IF ACCION$ = "" THEN           
1131   GOTO 1120        
1132 END IF                         'SENTENCIA IF QUE DECIDE QUE HACER EN BASE A RESPUESTA
1140 IF ACCION$ = "2" THEN
1141   GOTO 100                     'BORRAR NOS LLEVARIA AL MENU PRINCIPAL
1142 END IF
1150 ' Proceso de guardado
1160 OPEN F$ AS #2                          'ABRE EL ARCHIVO EN EL CANAL 2
1170 PRINT #2, CODIGO$ + "," + CANTIDAD$    'COPIAR LOS DATOS DE (CODIGO , CANTIDAD) 
1180 CLOSE #2                               'CIERRA EL CANAL Y VUELVE A MENU
1190 GOTO 100

2000 ' --- 2: DESCARGA ---
2010 CLS                        'LIMPIA
2020 PRINT "Ponga en cuna..."   
2030 PRINT "Y pulse ENT"
2040 IF INKEY$ <> CHR$(13) THEN     'CHR$(13) ES EL CODIGO DE LA TECLA ENTER, ESPERA HASTA RECIBIR ENT
2041   GOTO 2040
2042 END IF
2050 PRINT "Enviando..."
2060 XFILE "S", F$                  'COMANDO PARA ENVIAR EL ARCHIVO POR EL PUERTO DE LA CUNA.
2070 PRINT "Completado!"
2080 WAIT 0,2
2090 GOTO 100

3000 ' --- 3: BORRAR ---
3010 CLS
3020 PRINT "1:Confirmar Borrar"
3030 PRINT "2:Cancelar"
3040 B$ = INKEY$                    
3050 IF B$ = "" THEN
3051   GOTO 3040                        'BUCLE DE ESPERA 
3052 END IF
3060 IF B$ = "2" THEN
3061   GOTO 100                         'EN CASO DE CANCELAR AL MENU
3062 END IF
3070 KILL F$                            'ELIMINA EL ARCHIVO DE LA MEMORIA
3080 PRINT "Datos borrados!"
3090 WAIT 0,2
3100 GOTO 100

4000 ' --- 4: VER DATOS ---
4010 CLS
4020 OPEN F$ AS #2                  'ABRE EL ARCHIVO EN EL SEGUNDO CANAL
4030 L = 0                          'VARIABLE PARA GUARDAR ENTRADAS Y EVITAR SOBRECARGA EN LA PANTALLA
4040 IF EOF(2) THEN                 'COMPRUEBA MEDIANTE END OF FILE(EOF) SI HEMOS LLEGADO AL FINAL DEL ARCHIVO
4041   GOTO 4130                    'AL NO QUEDAR LINEAS SALTA A FINAL DE SECCION
4042 END IF
4050 INPUT #2, LINEA$               'LEE LAS LINEAS Y LAS GUARDA EN VARIABLE LINEA$
4060 PRINT LINEA$                   'LAS IMPRIME
4070 L= L + 1                       'SUMA 1 AL CONTADOR
4080 IF L < 5 THEN                  'CUANDO EL CONTADOR LLEGA A 5 PEDIMOS CONFIRMACION PARA SIGUIENTE PAGINA
4081 GOTO  4040
4082 END IF
4090 PRINT "(Pulse tecla...)"
4100 IF INKEY$ = "" THEN
4101   GOTO 4100                    'ESPERA HASTA QUE SE PULSA UNA TECLA
4102 END IF
4110 CLS                        'LIMPIA
4120 GOTO 4030                  'VUELVE A COMPROBAR SI HAY MAS LINEAS
4130 CLOSE #2                   'CIERRA ARCHIVO AL TERMINAR LA LECTURA
4140 PRINT "Fin de datos"
4150 WAIT 0,2
4160 GOTO 100

5000 ' --- 5: SALIR ---
5010 CLS
5020 PRINT "Saliendo..."
5030 WAIT 0,1
5040 END